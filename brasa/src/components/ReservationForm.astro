---
// Demo reservation form — validates and shows a confirmation client-side.
// To go live: POST to your API, or embed a Resy/OpenTable widget instead.
const field =
  "w-full rounded-sm border border-smoke bg-ash/60 px-4 py-3 text-bone placeholder:text-bone-mute/50 transition-colors duration-300 focus:border-brass focus:outline-none";
const label =
  "mb-2 block font-mono text-[0.68rem] uppercase tracking-[0.18em] text-bone-mute";
const chevron =
  "pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-bone-mute";

const times = [
  "5:30 PM", "6:00 PM", "6:30 PM", "7:00 PM", "7:30 PM",
  "8:00 PM", "8:30 PM", "9:00 PM", "9:30 PM", "10:00 PM",
];
const parties = ["1", "2", "3", "4", "5", "6", "7", "8", "9+ (please call)"];
const seatings = ["No preference", "Dining Room", "The Bar", "Garden Patio", "Chef's Counter"];
---

<div class="relative">
  <form id="reservation-form" novalidate class="grid gap-6 sm:grid-cols-2">
    <div>
      <label class={label} for="r-name">Full name</label>
      <input class={field} id="r-name" name="name" type="text" autocomplete="name" required placeholder="Jane Doe" />
    </div>
    <div>
      <label class={label} for="r-phone">Phone</label>
      <input class={field} id="r-phone" name="phone" type="tel" autocomplete="tel" required placeholder="(305) 555-0142" />
    </div>
    <div class="sm:col-span-2">
      <label class={label} for="r-email">Email</label>
      <input class={field} id="r-email" name="email" type="email" autocomplete="email" required placeholder="you@email.com" />
    </div>

    <div>
      <label class={label} for="r-date">Date</label>
      <input class={field} id="r-date" name="date" type="date" required />
    </div>
    <div class="relative">
      <label class={label} for="r-time">Time</label>
      <select class={`${field} appearance-none pr-10`} id="r-time" name="time" required>
        {times.map((t) => <option value={t}>{t}</option>)}
      </select>
      <svg class={chevron} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round"/></svg>
    </div>

    <div class="relative">
      <label class={label} for="r-party">Party size</label>
      <select class={`${field} appearance-none pr-10`} id="r-party" name="party" required>
        {parties.map((p) => <option value={p}>{p}</option>)}
      </select>
      <svg class={chevron} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round"/></svg>
    </div>
    <div class="relative">
      <label class={label} for="r-seating">Seating</label>
      <select class={`${field} appearance-none pr-10`} id="r-seating" name="seating">
        {seatings.map((s) => <option value={s}>{s}</option>)}
      </select>
      <svg class={chevron} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round"/></svg>
    </div>

    <div class="sm:col-span-2">
      <label class={label} for="r-notes">Special requests <span class="lowercase tracking-normal">(optional)</span></label>
      <textarea class={`${field} resize-none`} id="r-notes" name="notes" rows="3" placeholder="Anniversary, dietary needs, accessibility…"></textarea>
    </div>

    <p id="r-error" class="hidden text-sm text-ember sm:col-span-2" role="alert"></p>

    <div class="sm:col-span-2">
      <button type="submit" class="btn btn-primary w-full sm:w-auto">Request reservation</button>
      <p class="mt-3 font-mono text-[0.68rem] uppercase tracking-[0.15em] text-bone-mute">
        Parties of 9+ — please call <a href="tel:+13055550142" class="text-brass link-underline">(305) 555-0142</a>
      </p>
    </div>
  </form>

  <!-- Success state -->
  <div id="reservation-success" class="hidden border border-brass/40 bg-char/60 p-10 text-center">
    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full border border-brass text-brass">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h3 class="display text-3xl text-bone">Request received</h3>
    <p id="reservation-summary" class="mx-auto mt-3 max-w-md text-sm text-bone-mute"></p>
    <p class="mx-auto mt-2 max-w-md text-sm text-bone-mute">We'll confirm by email and text shortly. The fire will be ready.</p>
    <button type="button" id="reservation-reset" class="btn btn-ghost mt-7">Make another request</button>
  </div>
</div>

<script>
  const form = document.getElementById("reservation-form") as HTMLFormElement | null;
  const success = document.getElementById("reservation-success");
  const summary = document.getElementById("reservation-summary");
  const errorEl = document.getElementById("r-error");
  const dateInput = document.getElementById("r-date") as HTMLInputElement | null;

  // Disallow past dates
  if (dateInput) dateInput.min = new Date().toISOString().split("T")[0];

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      errorEl?.classList.remove("hidden");
      if (errorEl) errorEl.textContent = "Please complete the required fields.";
      form.reportValidity();
      return;
    }
    errorEl?.classList.add("hidden");
    const data = new FormData(form);
    // TODO: replace with a real submission (fetch POST / Resy / OpenTable).
    if (summary) {
      summary.textContent = `Table for ${data.get("party")} · ${data.get("date")} at ${data.get("time")}, under ${data.get("name")}.`;
    }
    form.classList.add("hidden");
    success?.classList.remove("hidden");
    success?.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  document.getElementById("reservation-reset")?.addEventListener("click", () => {
    form?.reset();
    success?.classList.add("hidden");
    form?.classList.remove("hidden");
  });
</script>
