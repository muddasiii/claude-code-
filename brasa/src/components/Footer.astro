const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-smoke/60 bg-char">
  <div class="ember-glow" style="width:60%;height:120%;left:-10%;top:-20%;opacity:.4"></div>

  <div class="relative mx-auto max-w-7xl px-5 pb-12 pt-16 sm:px-8 sm:pt-20">
    <!-- CTA row -->
    <div class="flex flex-col items-start justify-between gap-8 border-b border-smoke/50 pb-14 md:flex-row md:items-end">
      <div>
        <p class="eyebrow mb-4">Reserve your table</p>
        <h2 class="display max-w-xl text-4xl sm:text-5xl">
          The fire is lit. <span class="text-brass">Join us.</span>
        </h2>
      </div>
      <a href="/reservations" class="btn btn-primary shrink-0">Book a table</a>
    </div>

    <!-- Columns -->
    <div class="grid grid-cols-2 gap-10 py-14 sm:grid-cols-3 lg:grid-cols-4">
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="display text-2xl tracking-[0.18em] text-bone">BRASA</a>
        <p class="mt-4 max-w-xs text-sm text-bone-mute">
          {site.tagline} in the heart of Miami's Design District. Prime cuts, white-oak embers, Florida waters.
        </p>
      </div>

      <div>
        <p class="eyebrow mb-4">Explore</p>
        <ul class="space-y-2.5 text-sm">
          {site.nav.map((l) => (
            <li>
              <a href={l.href} class="text-bone-dim transition-colors hover:text-brass">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-4">Hours</p>
        <ul class="space-y-2 text-sm text-bone-dim">
          {site.hours.map((h) => (
            <li class="flex flex-col">
              <span class="text-bone-mute">{h.days}</span>
              <span class="font-mono text-[0.8rem]">{h.time}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-4">Visit</p>
        <address class="space-y-3 text-sm not-italic text-bone-dim">
          <p>{site.address.line1}<br />{site.address.line2}</p>
          <p>
            <a href={site.phoneHref} class="font-mono hover:text-brass">{site.phone}</a><br />
            <a href={site.emailHref} class="hover:text-brass">{site.email}</a>
          </p>
        </address>
        <div class="mt-5 flex gap-3">
          {site.social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="flex h-10 w-10 items-center justify-center rounded-full border border-smoke text-bone-mute transition-colors hover:border-brass hover:text-brass"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={icons[s.icon]}></path>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col gap-4 border-t border-smoke/50 pt-8 text-xs text-bone-mute sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name} Steakhouse · Est. {site.established} · Miami, FL</p>
      <p class="max-w-md leading-relaxed">
        Consuming raw or undercooked meats may increase your risk of foodborne illness. Please enjoy responsibly.
      </p>
    </div>
  </div>
</footer>
