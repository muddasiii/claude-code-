---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import ReservationForm from "../components/ReservationForm.astro";
import { site } from "../data/site";
import { url } from "../lib/url";

const goodToKnow = [
  "Reservations are recommended. We hold a handful of seats at the bar for walk-ins each night.",
  "We allow a 15-minute grace period before releasing your table.",
  "Smart-casual dress, please — no athletic wear.",
  "Celebrating something? Tell us in the notes and we'll make it memorable.",
];
---

<Base
  title="Reservations"
  description="Reserve your table at BRASA — wood-fired steakhouse in Miami's Design District."
>
  <PageHero
    eyebrow="Reservations"
    title="Hold<br/>your table."
    intro="Tell us when, and we'll have the embers ready. For parties larger than eight, our team will take care of you directly."
  />

  <section class="mx-auto max-w-7xl px-5 py-20 sm:px-8 sm:py-24">
    <div class="grid gap-14 lg:grid-cols-[1.5fr_1fr] lg:gap-20">
      <div data-reveal>
        <ReservationForm />
      </div>

      <aside class="space-y-10 lg:border-l lg:border-smoke/40 lg:pl-12">
        <div data-reveal>
          <p class="eyebrow mb-4">Hours</p>
          <ul class="space-y-2">
            {
              site.hours.map((h) => (
                <li class="flex justify-between gap-6 border-b border-smoke/40 py-2 text-sm">
                  <span class="text-bone-dim">{h.days}</span>
                  <span class="font-mono text-bone-mute">{h.time}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div data-reveal data-reveal-delay="1">
          <p class="eyebrow mb-4">Good to know</p>
          <ul class="space-y-3 text-sm leading-relaxed text-bone-dim">
            {goodToKnow.map((g) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-brass" aria-hidden="true"></span>
                <span>{g}</span>
              </li>
            ))}
          </ul>
        </div>

        <div data-reveal data-reveal-delay="2">
          <p class="eyebrow mb-4">Large parties & events</p>
          <p class="text-sm text-bone-dim">
            For 9 or more, call
            <a href={site.phoneHref} class="text-brass link-underline">{site.phone}</a>
            or explore <a href={url("/private-events")} class="text-brass link-underline">private events</a>.
          </p>
        </div>

        <div data-reveal data-reveal-delay="3">
          <p class="eyebrow mb-4">Find us</p>
          <p class="text-sm text-bone-dim">{site.address.line1}<br />{site.address.line2}</p>
          <a href={site.address.maps} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm text-brass link-underline">Get directions</a>
        </div>
      </aside>
    </div>
  </section>
</Base>
